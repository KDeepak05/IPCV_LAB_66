# Project Specific Directories
# Ignore dataset videos (they are too large for Git)
src/dataset/**/*.mp4
src/dataset/**/*.avi
src/dataset/**/*.mkv
src/dataset/**/*.mov

# Ignore generated outputs (screenshots, saved videos, graphs)
src/outputs/**/*.mp4
src/outputs/**/*.png
src/outputs/**/*.jpg
src/outputs/**/*.csv
src/outputs/graphs/*
src/outputs/screenshots/*
src/outputs/videos/*

# Ignore the generated bundled code text file
src/project_code.txt
src/test_pipeline.py
src/generate_test_video.py
